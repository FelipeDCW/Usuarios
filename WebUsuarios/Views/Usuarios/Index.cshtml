<div class="mt-3">


    <div class="text-start mt-3">
        <a href="@Url.Action("ExportToExcel", "Usuarios", new { searchTerm = ViewBag.SearchTerm })" class="btn btn-success">
            <i class="fa-solid fa-file-excel"></i>&nbsp; Excel
        </a>
    </div>

    @using (Html.BeginForm("Index", "Usuarios", FormMethod.Get, new { @class = "d-flex justify-content-end" }))
    {


        <div class="form-group mr-5">
            <input type="text" name="searchTerm" class="form-control" placeholder="Buscar..." value="@ViewBag.SearchTerm" />
        </div>
        <button type="submit" class="btn btn-secondary">Buscar</button>
        <a href="@Url.Action("Index", "Usuarios")" class="btn btn-info">Limpiar</a>


    }
</div>


@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
}
@if (ViewBag.ErrorMessage != null)
{
    <div class="alert alert-danger">@ViewBag.ErrorMessage</div>
}

<table class="table table-hover table-bordered table-strip mt-3">
    <thead class="bg-primary text-white text-center">
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Nombre)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Rut)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Correo)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.FechaNacimiento)
            </th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @if (Model.Any())
        {
            foreach (var item in Model)
            {
                <tr>
                    <td>
                        @Html.DisplayFor(modelItem => item.Nombre)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.Rut)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.Correo)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.FechaNacimiento)                        
                    </td>
                    <td class="text-center">
                        <a href="@Url.Action("Edit", new { id = item.Id })" class="btn btn-secondary">
                            <i class="fa-solid fa-pen-to-square"></i>
                        </a>
                        <a href="@Url.Action("Delete", new { id = item.Id })" class="btn btn-danger">
                            <i class="fa-solid fa-trash"></i>
                        </a>

                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="5">No se encontraron usuarios.</td>
            </tr>
        }
    </tbody>
</table>

<nav aria-label="Page navigation">
    <ul class="pagination justify-content-end">
        @if (ViewBag.HasPreviousPage)
        {
            <li class="page-item">
                <a class="page-link" href="@Url.Action("Index", new { page = ViewBag.CurrentPage - 1, searchTerm = ViewBag.SearchTerm })">Anterior</a>
            </li>
        }
        @for (int i = 1; i <= ViewBag.TotalPages; i++)
        {
            <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                <a class="page-link" href="@Url.Action("Index", new { page = i, searchTerm = ViewBag.SearchTerm })">@i</a>
            </li>
        }
        @if (ViewBag.HasNextPage)
        {
            <li class="page-item">
                <a class="page-link" href="@Url.Action("Index", new { page = ViewBag.CurrentPage + 1, searchTerm = ViewBag.SearchTerm })">Siguiente</a>
            </li>
        }
    </ul>
</nav>

@section scripts {
    <script>
        $(document).ready(function () {
            // Script para ocultar los mensajes de TempData después de unos segundos
            setTimeout(function () {
                $(".alert").fadeOut("slow");
            }, 5000); // 5 segundos
        });
    </script>
}